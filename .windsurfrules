     Windsurf を使う場合のみ参照。2026-03-28 -->
<rules>
  <project name="OtakuPulse" description="AI-powered otaku news aggregator">

    <!-- ===== スタック ===== -->
    <stack>
      <frontend>React 19 + TypeScript 5 + Vite 7 + Tailwind CSS 4 + Zustand 5</frontend>
      <backend>Rust + Tauri v2</backend>
      <tools>Biome v2 (lint/format), feed-rs (RSS), scraper (HTML)</tools>
    </stack>

    <!-- ===== 4 Wings ===== -->
    <wings>
      <wing name="Dashboard" description="ホーム画面・概要表示" />
      <wing name="Feed" description="ニュースフィード一覧・閲覧" />
      <wing name="Digest" description="AI 要約・ダイジェスト生成" />
      <wing name="Settings" description="ユーザー設定・フィード管理" />
    </wings>

    <!-- ===== 4層アーキテクチャ (Rust) ===== -->
    <architecture>
      <layer name="commands" path="src-tauri/src/commands/">
        Tauri コマンド（#[tauri::command]）。薄いレイヤー。
        ビジネスロジック禁止 — services/ を呼ぶだけ。
      </layer>
      <layer name="services" path="src-tauri/src/services/">
        ビジネスロジック。テスト可能な純粋関数中心。
        外部 I/O に直接依存しない — infra/ を経由する。
      </layer>
      <layer name="infra" path="src-tauri/src/infra/">
        外部 I/O（HTTP, DB, ファイルシステム）。
        reqwest, sqlx, tokio::fs などのラッパー。
      </layer>
      <layer name="parsers" path="src-tauri/src/parsers/">
        フィード・BBCode パーサー。ステートレスな変換のみ。
        feed-rs ラッパー、BBCode→HTML 変換など。
      </layer>
    </architecture>

    <!-- ===== ファイル構造 ===== -->
    <file-structure>
      <![CDATA[
otaku-pulse/
├── src/                          # React フロントエンド
│   ├── components/               # 共通コンポーネント
│   ├── features/                 # Wing 別機能モジュール
│   │   ├── dashboard/
│   │   ├── feed/
│   │   ├── digest/
│   │   └── settings/
│   ├── hooks/                    # カスタムフック
│   ├── stores/                   # Zustand ストア
│   ├── lib/                      # ユーティリティ
│   ├── types/                    # 型定義
│   ├── App.tsx
│   └── main.tsx
├── src-tauri/
│   └── src/
│       ├── commands/             # Tauri コマンド
│       ├── services/             # ビジネスロジック
│       ├── infra/                # 外部 I/O
│       ├── parsers/              # パーサー
│       ├── error.rs              # AppError 定義
│       ├── lib.rs
│       └── main.rs
├── CLAUDE.md
├── AGENTS.md
├── HANDOFF.md
└── .windsurfrules
      ]]>
    </file-structure>

    <!-- ===== コーディングルール ===== -->
    <coding-rules>
      <rule id="1" name="complete-code">
        省略・プレースホルダー禁止。常に完全なコードを書く。
        「// TODO: implement later」のような記述は許可しない。
      </rule>
      <rule id="2" name="error-handling">
        Rust: ? 演算子 + AppError。unwrap() は本番コードで禁止。
        TS: try/catch + 構造化エラーアクセス。Error インスタンスとして扱わない。
      </rule>
      <rule id="3" name="no-debug-output">
        console.log / println! / dbg! 禁止。
        TS: pino、Rust: tracing を使用する。
      </rule>
      <rule id="4" name="naming">
        TS: camelCase (変数), PascalCase (コンポーネント), UPPER_SNAKE_CASE (定数)。
        Rust: snake_case (変数/関数), PascalCase (型), UPPER_SNAKE_CASE (定数)。
      </rule>
      <rule id="5" name="tailwind-only">
        スタイリングは Tailwind CSS のみ。インラインスタイル・CSS モジュール禁止。
      </rule>
      <rule id="6" name="feed-rs-mandatory">
        RSS/Atom パースは feed-rs クレート必須。自前パーサー禁止。
      </rule>
      <rule id="7" name="bbcode-in-parsers">
        BBCode パーサーは parsers/ ディレクトリに配置する。
        他のレイヤーに散在させない。
      </rule>
    </coding-rules>

    <!-- ===== デフォルト完了要件 ===== -->
    <requirements>
      <check command="cargo check" description="コンパイルチェック" />
      <check command="cargo clippy -- -D warnings" description="Clippy 警告ゼロ" />
      <check command="npm run check" description="Biome lint/format エラーゼロ" />
      <check command="npm run typecheck" description="TypeScript 型エラーゼロ" />
    </requirements>

    <!-- ===== パターン例 ===== -->
    <patterns>
      <pattern name="zustand-store">
        <![CDATA[
// stores/feed-store.ts
import { create } from "zustand";
import type { FeedItem } from "@/types/feed";

interface FeedState {
  items: FeedItem[];
  isLoading: boolean;
  error: string | null;
  fetchItems: (feedId: number) => Promise<void>;
}

export const useFeedStore = create<FeedState>((set) => ({
  items: [],
  isLoading: false,
  error: null,
  fetchItems: async (feedId: number): Promise<void> => {
    set({ isLoading: true, error: null });
    try {
      const items = await invoke<FeedItem[]>("get_feed_items", { feedId });
      set({ items, isLoading: false });
    } catch (error: unknown) {
      const message =
        typeof error === "object" && error !== null && "message" in error
          ? (error as { message: string }).message
          : JSON.stringify(error);
      set({ error: message, isLoading: false });
    }
  },
}));
        ]]>
      </pattern>

      <pattern name="rust-command">
        <![CDATA[
// commands/feed.rs
use tauri::State;
use sqlx::SqlitePool;
use crate::error::AppError;
use crate::services;

#[tauri::command]
pub async fn get_feed_items(
    db: State<'_, SqlitePool>,
    feed_id: i64,
) -> Result<Vec<FeedItem>, AppError> {
    services::feed::list_items(&db, feed_id).await
}
        ]]>
      </pattern>
    </patterns>

    <!-- ===== ワークフロー ===== -->
    <workflow>
      <step order="1" command="npm run check" description="Biome lint/format" />
      <step order="2" command="npm run typecheck" description="TypeScript 型チェック" />
      <step order="3" command="cargo clippy -- -D warnings" description="Rust lint" />
      <step order="4" action="HANDOFF.md 更新" description="ステータスを review に変更" />
    </workflow>

  </project>
</rules>
